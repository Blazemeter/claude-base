{
  "$comment": "BU-level baseline Claude Code settings. Every product's .claude/settings.local.json must extend this. CI rejects any product that weakens a deny rule.",
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep(**)",
      "Glob(**)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git fetch*)",
      "Bash(git add*)",
      "Bash(git commit -m:*)",
      "Bash(git push origin:*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh api repos/*)",
      "Bash(mvn clean*)",
      "Bash(mvn test*)",
      "Bash(mvn install*)",
      "Bash(yarn install*)",
      "Bash(yarn test*)",
      "Bash(yarn build*)",
      "Bash(npm test*)",
      "Bash(npm run*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr review --approve*)",
      "Bash(rm -rf*)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(aws s3 rm*)",
      "Bash(aws ecs delete-service*)",
      "Bash(aws rds delete-db-instance*)",
      "Bash(kubectl delete namespace*)",
      "Bash(mongo*drop*)",
      "Bash(psql*DROP*)",
      "Bash(curl*|*sh*)",
      "Bash(wget*|*sh*)",
      "Bash(curl*|*bash*)",
      "Bash(wget*|*bash*)",
      "Bash(*eval*$(curl*)",
      "Bash(aws iam delete-*)",
      "Bash(aws iam detach-*)",
      "Bash(aws kms schedule-key-deletion*)",
      "Bash(aws secretsmanager delete-secret*)",
      "Bash(docker system prune*)",
      "Bash(terraform destroy*)",
      "Bash(helm uninstall*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets.yaml)",
      "Read(**/secrets.yml)",
      "Read(**/credentials.json)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.aws/credentials)",
      "Read(**/.kube/config)"
    ]
  }
}
