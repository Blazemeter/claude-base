{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Skill frontmatter",
  "type": "object",
  "required": ["name", "category", "owner", "permission-tier", "version", "status", "last-reviewed"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "kebab-case, must match the plugin directory name"
    },
    "category": {
      "enum": ["onboarding", "build-test", "vcs-pr", "issue-mgmt", "ci-cd", "observability", "data-store", "security", "hooks"]
    },
    "owner": {
      "type": "string",
      "pattern": "^team-[a-z][a-z0-9-]*$"
    },
    "permission-tier": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "mcps-used": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "enum": ["experimental", "stable", "deprecated"]
    },
    "last-reviewed": {
      "type": "string",
      "format": "date"
    }
  },
  "additionalProperties": false
}
